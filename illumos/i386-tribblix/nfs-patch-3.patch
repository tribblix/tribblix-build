diff --git a/usr/src/uts/common/fs/nfs/nfs4x_slrc.c b/usr/src/uts/common/fs/nfs/nfs4x_slrc.c
new file mode 100644
index 0000000..dddea1b
--- /dev/null
+++ b/usr/src/uts/common/fs/nfs/nfs4x_slrc.c
@@ -0,0 +1,424 @@
+/*
+ * CDDL HEADER START
+ *
