+	ulong_t			offset;
+	char			*who;
+
+	who = modgetsymname((uintptr_t)caller(), &offset);
+	cmn_err(CE_NOTE, "rfs41_rs_erase: (%s, dsp = 0x%p)", who, dsp);
+#endif /* DEBUG_VERBOSE */
+
+	ASSERT(dsp != NULL);
+	if (dsp->rds_rs.refcnt > 0) {
+		rfs41_deleg_rs_rele(dsp);
+		rfs4_deleg_state_rele(dsp);
+	}
+}
